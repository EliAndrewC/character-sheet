# L7R Character Builder - local development env template
#
# Copy this file to .env and fill in the values you need. .env is
# gitignored; .env.example is checked in so the set of variables is
# version-controlled.
#
# In production, secrets are set as Fly secrets (`fly secrets set ...`)
# rather than via .env. See CLAUDE.md for which variables go where.


# ---------------------------------------------------------------------
# Test-user login (local dev only)
# ---------------------------------------------------------------------
# UUID-to-Discord-ID map for the /auth/test-login/<uuid> bypass routes.
# Format: uuid:discord_id,uuid:discord_id
# Generate fresh UUIDs with `python3 -c "import uuid; print(uuid.uuid4())"`.
TEST_LOGIN_TOKENS="00000000-0000-0000-0000-000000000001:test_user_1,00000000-0000-0000-0000-000000000002:test_user_2"


# ---------------------------------------------------------------------
# Google OAuth 2.0 - Google Sheets export
# ---------------------------------------------------------------------
# These come from Google Cloud Console > APIs & Services > Credentials.
# See CLAUDE.md "Google Sheets Export" for setup notes.
GOOGLE_CLIENT_ID="xxxxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxxxxxxxxxxxxxxxx"


# ---------------------------------------------------------------------
# Fly.io deploy token
# ---------------------------------------------------------------------
# Generate with `fly tokens create deploy` (run locally or in CI).
# Not needed to run the app - only to `fly deploy` from this shell.
FLY_API_TOKEN=""


# ---------------------------------------------------------------------
# Google Gemini - character import pipeline
# ---------------------------------------------------------------------
# See import-design/CLAUDE.md and top-level CLAUDE.md "Character Import".
# Get a key at https://aistudio.google.com/apikey.
GEMINI_API_KEY="AIza..."
# Override only when experimenting with different Gemini models; the
# defaults are good for production.
GEMINI_MODEL_PRIMARY="gemini-2.5-flash"
GEMINI_MODEL_FALLBACK="gemini-2.5-pro"


# ---------------------------------------------------------------------
# Character import - runtime knobs (all have sensible defaults)
# ---------------------------------------------------------------------
# Kill switch; set to "false" to disable the /import route without
# redeploying.
# IMPORT_ENABLED="true"
#
# Per-user per-24h limit on successful import jobs.
# IMPORT_RATE_LIMIT_PER_DAY="10"
#
# Hard cap on uploaded file size and URL-fetched content size, in MB.
# Rejected before any LLM call happens.
# IMPORT_MAX_UPLOAD_MB="1"
#
# URL fetcher timeouts / hop limit for the SSRF-hardened client.
# IMPORT_URL_FETCH_TIMEOUT_SEC="20"
# IMPORT_MAX_REDIRECTS="3"
#
# Gemini-call tuning. 60s per call, 2s retry backoff, 8192 max output
# tokens is more than enough for our JSON schema.
# IMPORT_LLM_TIMEOUT_SEC="60"
# IMPORT_LLM_RETRY_BACKOFF_SEC="2.0"
# IMPORT_LLM_MAX_OUTPUT_TOKENS="8192"
#
# Multimodal PDF fallback: cap pages to send, DPI for rendering.
# IMPORT_MAX_PDF_PAGES="10"
# IMPORT_PDF_RENDER_DPI="150"


# ---------------------------------------------------------------------
# Not a real env var - do NOT set in production
# ---------------------------------------------------------------------
# Set to "1" only in e2e test harnesses. Short-circuits the real Gemini
# API and returns canned responses based on document content markers
# (see app/services/import_llm.py::_stub_response_for).
# IMPORT_USE_TEST_STUB=""
